# ─── DATABASE ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://purferme:password@localhost:5432/purferme_db
SYNC_DATABASE_URL=postgresql://purferme:password@localhost:5432/purferme_db

# ─── JWT ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_very_long_random_secret_key_at_least_64_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── APP ───────────────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
DEBUG=true
PROJECT_NAME=PurFerme Traceability API
API_V1_STR=/api/v1

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── RATE LIMITING ─────────────────────────────────────────────────────────────
PUBLIC_RATE_LIMIT=100        # requests per minute on public endpoints

# ─── FIRST SUPER-ADMIN (seeded on first run) ───────────────────────────────────
FIRST_SUPERADMIN_EMAIL=admin@purferme.com
FIRST_SUPERADMIN_PASSWORD=ChangeMe@123
